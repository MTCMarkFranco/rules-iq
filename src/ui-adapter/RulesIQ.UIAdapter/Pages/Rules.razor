@page "/rules"
@using RulesIQ.RuntimeEngine.Services
@inject IRuleRetrievalService RetrievalService

<PageTitle>Rule Browser</PageTitle>

<h2>Rule Browser</h2>
<p>Browse the extracted rules from Canadian lending policy documents with full source document traceability.</p>

@if (_loading)
{
    <div class="d-flex align-items-center">
        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
        <span>Loading rules from the search index...</span>
    </div>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_workflow is not null)
{
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <strong>@_workflow.WorkflowName</strong>
                <span class="badge bg-secondary ms-2">@(_workflow.RulesetVersion ?? "N/A")</span>
            </div>
            <small class="text-muted">@_workflow.Rules.Count rules &middot; Last indexed: @(_workflow.RulesetPublishedTimestamp?.ToString("yyyy-MM-dd HH:mm") ?? "N/A")</small>
        </div>
        <div class="card-body">
            <table class="table table-striped table-sm">
                <thead>
                    <tr>
                        <th>Rule Name</th>
                        <th>Expression</th>
                        <th>Success Event</th>
                        <th>Error Message</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rule in _workflow.Rules.OrderBy(r => r.RuleName))
                    {
                        <tr>
                            <td>@rule.RuleName</td>
                            <td><code>@rule.Expression</code></td>
                            <td>@rule.SuccessEvent</td>
                            <td>@rule.ErrorMessage</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning">No rules found in the search index.</div>
}

@code {
    private NormalizedWorkflow? _workflow;
    private string? _error;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _workflow = await RetrievalService.RetrieveAllRulesAsync();
            if (_workflow.Rules.Count == 0)
                _workflow = null;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load rules: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}
