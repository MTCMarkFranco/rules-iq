      "constant": true
    },
    "InspectorIsAppraiser": {
      "constant": true
    },
    "CreditScoreStatus": {
      "source": "CreditScore",
      "condition": "lessThan",
      "value": "650",
      "trueResult": "Low",
      "falseResult": "Acceptable"
    },
    "DebtServiceabilityRatioStatus": {
      "source": "GDS",
      "condition": "greaterThan",
      "value": "39",
      "trueResult": "High",
      "falseResult": "Acceptable"
    },
    "IncomeVerificationStatus": {
      "source": "EmploymentStatus",
      "condition": "equals",
      "value": "Employed",
      "trueResult": "Sufficient",
      "falseResult": "Insufficient"
    },
    "PropertyCreditRiskStatus": {
      "source": "LTV",
      "condition": "greaterThan",
      "value": "80",
      "trueResult": "Elevated",
      "falseResult": "Normal"
    },
    "IncomeVerificationNotContradictedByOtherInformation": {
      "constant": true
    },
    "LenderIsFederallyRegulated": {
      "source": "LenderType",
      "condition": "equals",
      "value": "FederallyRegulated"
    },
    "NewMortgagePaymentArrangementAgreed": {
