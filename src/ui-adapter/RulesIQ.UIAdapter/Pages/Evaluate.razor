@page "/evaluate"
@using RulesIQ.RuntimeEngine.Services
@using RulesIQ.UIAdapter.Services
@inject IRuleEvaluationService EvaluationService
@inject ITraceabilityService TraceabilityService

<PageTitle>Loan Eligibility Evaluation</PageTitle>

<h2>Loan Eligibility Evaluation</h2>

<div class="row">
    <div class="col-md-5">
        <div class="card mb-3">
            <div class="card-header"><strong>Applicant Information</strong></div>
            <div class="card-body">
                <EditForm Model="@_input" OnValidSubmit="RunEvaluation">
                    <div class="mb-2">
                        <label class="form-label">Age</label>
                        <InputNumber class="form-control" @bind-Value="_input.Age" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Province</label>
                        <InputText class="form-control" @bind-Value="_input.Province" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Residency Status</label>
                        <InputSelect class="form-control" @bind-Value="_input.ResidencyStatus">
                            <option value="Citizen">Citizen</option>
                            <option value="PermanentResident">Permanent Resident</option>
                            <option value="WorkPermit">Work Permit</option>
                            <option value="Other">Other</option>
                        </InputSelect>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Annual Income (CAD)</label>
                        <InputNumber class="form-control" @bind-Value="_input.AnnualIncome" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">GDS Ratio (%)</label>
                        <InputNumber class="form-control" @bind-Value="_input.GDS" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">TDS Ratio (%)</label>
                        <InputNumber class="form-control" @bind-Value="_input.TDS" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Credit Score</label>
                        <InputNumber class="form-control" @bind-Value="_input.CreditScore" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Employment Status</label>
                        <InputSelect class="form-control" @bind-Value="_input.EmploymentStatus">
                            <option value="Employed">Employed</option>
                            <option value="SelfEmployed">Self-Employed</option>
                            <option value="Unemployed">Unemployed</option>
                            <option value="Retired">Retired</option>
                        </InputSelect>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Employment Duration (months)</label>
                        <InputNumber class="form-control" @bind-Value="_input.EmploymentDurationMonths" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Loan Amount (CAD)</label>
                        <InputNumber class="form-control" @bind-Value="_input.LoanAmount" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Property Value (CAD)</label>
                        <InputNumber class="form-control" @bind-Value="_input.PropertyValue" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Down Payment (%)</label>
                        <InputNumber class="form-control" @bind-Value="_input.DownPaymentPercent" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">LTV (%)</label>
                        <InputNumber class="form-control" @bind-Value="_input.LTV" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Loan Type</label>
                        <InputSelect class="form-control" @bind-Value="_input.LoanType">
                            <option value="Mortgage">Mortgage</option>
                            <option value="PersonalLoan">Personal Loan</option>
                            <option value="LineOfCredit">Line of Credit</option>
                            <option value="AutoLoan">Auto Loan</option>
                        </InputSelect>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Lender Type</label>
                        <InputSelect class="form-control" @bind-Value="_input.LenderType">
                            <option value="FederallyRegulated">Federally Regulated</option>
                            <option value="ProvinciallyRegulated">Provincially Regulated</option>
                        </InputSelect>
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary" disabled="@_evaluating">
                            @(_evaluating ? "Evaluating..." : "Evaluate Compliance")
                        </button>
                        <button type="button" class="btn btn-outline-secondary ms-2" @onclick="LoadCanonicalPersona">
                            Load Test Persona
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        @if (_result is not null)
        {
            <ComplianceDashboard Result="@_result" />
        }
        else if (_error is not null)
        {
            <div class="alert alert-danger">@_error</div>
        }
    </div>
</div>

@code {
    private LoanEligibilityInput _input = new();
    private EvaluationResult? _result;
    private string? _error;
    private bool _evaluating;

    private void LoadCanonicalPersona()
    {
        _input = LoanEligibilityInput.CanonicalTestPersona;
    }

    private async Task RunEvaluation()
    {
        _evaluating = true;
        _result = null;
        _error = null;

        try
        {
            var workflow = GetSampleWorkflow();
            _result = await EvaluationService.EvaluateAsync(
                workflow, _input, "Determine loan eligibility for personal loan application");
        }
        catch (Exception ex)
        {
            _error = $"Evaluation failed: {ex.Message}";
        }
        finally
        {
            _evaluating = false;
        }
    }

    private static NormalizedWorkflow GetSampleWorkflow()
    {
        return new NormalizedWorkflow
        {
            WorkflowName = "CanadianLoanEligibility",
            RulesetVersion = "v1.0.0",
            SourceDocumentVersion = "2024.1",
            RulesetPublishedTimestamp = DateTimeOffset.UtcNow,
            Rules =
            [
                new NormalizedRule
                {
                    RuleName = "MinimumAgeRequirement",
                    Expression = "input1.Age >= 18",
                    SuccessEvent = "Applicant meets minimum age requirement",
                    ErrorMessage = "Applicant must be at least 18 years of age",
                    RuleExpressionType = "LambdaExpression",
                    Metadata = new NormalizedRuleMetadata { SourceDocuments = [new SourceDocumentMetadata { SourceDocumentId = "OSFI-B20", SourceUri = "osfi-b20.pdf", PageNumber = 3 }] }
                },
                new NormalizedRule
                {
                    RuleName = "ResidencyRequirement",
                    Expression = "input1.ResidencyStatus == \"Citizen\" || input1.ResidencyStatus == \"PermanentResident\" || (input1.ResidencyStatus == \"WorkPermit\")",
                    SuccessEvent = "Applicant meets residency requirement",
                    ErrorMessage = "Applicant must be a Canadian citizen, permanent resident, or hold a valid work permit",
                    RuleExpressionType = "LambdaExpression",
                    Metadata = new NormalizedRuleMetadata { SourceDocuments = [new SourceDocumentMetadata { SourceDocumentId = "OSFI-B20", SourceUri = "osfi-b20.pdf", PageNumber = 4 }] }
                },
                new NormalizedRule
                {
                    RuleName = "MinimumIncomeRequirement",
                    Expression = "input1.AnnualIncome >= 25000",
                    SuccessEvent = "Applicant meets minimum income requirement",
                    ErrorMessage = "Applicant gross annual income must be at least $25,000 CAD",
                    RuleExpressionType = "LambdaExpression",
                    Metadata = new NormalizedRuleMetadata { SourceDocuments = [new SourceDocumentMetadata { SourceDocumentId = "OSFI-B20", SourceUri = "osfi-b20.pdf", PageNumber = 5 }] }
                },
                new NormalizedRule
                {
                    RuleName = "MaxGrossDebtServiceRatio",
                    Expression = "input1.GDS <= 39",
                    SuccessEvent = "GDS ratio within acceptable limit",
                    ErrorMessage = "Applicant GDS ratio must not exceed 39%",
                    RuleExpressionType = "LambdaExpression",
                    Metadata = new NormalizedRuleMetadata { SourceDocuments = [new SourceDocumentMetadata { SourceDocumentId = "OSFI-B20", SourceUri = "osfi-b20.pdf", PageNumber = 6 }] }
                },
                new NormalizedRule
                {
                    RuleName = "MaxTotalDebtServiceRatio",
                    Expression = "input1.TDS <= 44",
                    SuccessEvent = "TDS ratio within acceptable limit",
                    ErrorMessage = "Applicant TDS ratio must not exceed 44%",
                    RuleExpressionType = "LambdaExpression",
                    Metadata = new NormalizedRuleMetadata { SourceDocuments = [new SourceDocumentMetadata { SourceDocumentId = "OSFI-B20", SourceUri = "osfi-b20.pdf", PageNumber = 6 }] }
                },
                new NormalizedRule
                {
                    RuleName = "MinimumCreditScore",
                    Expression = "input1.CreditScore >= 650",
                    SuccessEvent = "Applicant meets minimum credit score",
                    ErrorMessage = "Applicant credit score must be at least 650",
                    RuleExpressionType = "LambdaExpression",
                    Metadata = new NormalizedRuleMetadata { SourceDocuments = [new SourceDocumentMetadata { SourceDocumentId = "OSFI-B20", SourceUri = "osfi-b20.pdf", PageNumber = 7 }] }
                },
                new NormalizedRule
                {
                    RuleName = "MinimumEmploymentDuration",
                    Expression = "input1.EmploymentDurationMonths >= 6",
                    SuccessEvent = "Applicant meets minimum employment duration",
                    ErrorMessage = "Applicant must have been employed for at least 6 months",
                    RuleExpressionType = "LambdaExpression",
                    Metadata = new NormalizedRuleMetadata { SourceDocuments = [new SourceDocumentMetadata { SourceDocumentId = "OSFI-B20", SourceUri = "osfi-b20.pdf", PageNumber = 8 }] }
                }
            ]
        };
    }
}
