@page "/"

<PageTitle>Rules-IQ — Compliance Evaluation</PageTitle>

<h1>Rules-IQ Compliance Engine</h1>
<p class="lead">Deterministic policy rule evaluation powered by Microsoft RulesEngine.</p>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Evaluate Compliance</h5>
                <p class="card-text">Submit applicant data against the Canadian Loan Eligibility rules.</p>
                <a href="/evaluate" class="btn btn-primary">Start Evaluation</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Rule Browser</h5>
                <p class="card-text">Browse extracted rules with full source document traceability.</p>
                <a href="/rules" class="btn btn-outline-primary">Browse Rules</a>
            </div>
        </div>
    </div>
</div>
