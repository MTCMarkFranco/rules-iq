@using System.Text.Json

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Compliance Result</strong>
        <span class="badge @GetComplianceBadgeClass()">
            @Result.ComplianceScore.CompliancePercentage% Compliant
        </span>
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col text-center">
                <h1 class="display-4 @GetComplianceTextClass()">
                    @Result.ComplianceScore.CompliancePercentage%
                </h1>
                <p class="text-muted">
                    @Result.ComplianceScore.RulesPassed of @Result.ComplianceScore.TotalRulesEvaluated rules passed
                    @{
                        var notEvaluatedCount = Result.RulesSnapshot.Rules.Count(r => r.Result == "Not Evaluated");
                        if (notEvaluatedCount > 0)
                        {
                            <span class="text-secondary">(@notEvaluatedCount not evaluated — insufficient data)</span>
                        }
                    }
                </p>
            </div>
        </div>

        <div class="mb-3 p-2 bg-light rounded">
            <small class="text-muted">
                <strong>Ruleset Version:</strong> @(Result.VersionFingerprint.RulesetVersion ?? "N/A") |
                <strong>Evaluated:</strong> @Result.VersionFingerprint.EvaluationTimestamp.ToString("yyyy-MM-dd HH:mm:ss UTC")
            </small>
        </div>

        <h5>Rule Results</h5>
        @foreach (var rule in Result.RulesSnapshot.Rules)
        {
            <div class="card mb-2 @GetRuleCardClass(rule.Result)">
                <div class="card-body py-2 px-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@FormatRuleName(rule.RuleName)</strong>
                            <br />
                            <code class="small">@rule.Expression</code>
                        </div>
                        <span class="badge @GetRuleBadgeClass(rule.Result)">
                            @GetRuleIcon(rule.Result)
                        </span>
                    </div>
                    @if (rule.Result == "Passed" && rule.SuccessEvent is not null)
                    {
                        <div class="text-success small mt-1">
                            <em>@rule.SuccessEvent</em>
                        </div>
                    }
                    @if (rule.Result is "Failed" or "Not Evaluated" or "Indeterminate" && rule.ErrorMessage is not null)
                    {
                        <div class="@GetRuleMessageClass(rule.Result) small mt-1">
                            <em>@rule.ErrorMessage</em>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="mt-3">
            <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleSnapshot">
                @(_showSnapshot ? "Hide" : "Show") Rules Snapshot
            </button>
            <button class="btn btn-sm btn-outline-primary ms-2" @onclick="ExportJson">
                Export JSON
            </button>
        </div>

        @if (_showSnapshot)
        {
            <pre class="mt-2 p-3 bg-light border rounded" style="max-height:400px;overflow:auto;">@GetFormattedJson()</pre>
        }
    </div>
</div>

@code {
    [Parameter]
    public EvaluationResult Result { get; set; } = default!;

    private bool _showSnapshot;

    private string GetComplianceBadgeClass()
    {
        return Result.ComplianceScore.CompliancePercentage switch
        {
            >= 80 => "bg-success",
            >= 50 => "bg-warning text-dark",
            _ => "bg-danger"
        };
    }

    private string GetComplianceTextClass()
    {
        return Result.ComplianceScore.CompliancePercentage switch
        {
            >= 80 => "text-success",
            >= 50 => "text-warning",
            _ => "text-danger"
        };
    }

    private static string FormatRuleName(string ruleName)
    {
        return System.Text.RegularExpressions.Regex.Replace(ruleName, "(\\B[A-Z])", " $1");
    }

    private static string GetRuleCardClass(string result) => result switch
    {
        "Passed" => "border-success",
        "Not Evaluated" => "border-warning",
        "Indeterminate" => "border-warning",
        _ => "border-danger"
    };

    private static string GetRuleBadgeClass(string result) => result switch
    {
        "Passed" => "bg-success",
        "Not Evaluated" => "bg-secondary",
        "Indeterminate" => "bg-warning text-dark",
        _ => "bg-danger"
    };

    private static string GetRuleIcon(string result) => result switch
    {
        "Passed" => "\u2705 Passed",
        "Not Evaluated" => "\u26a0\ufe0f Not Evaluated",
        "Indeterminate" => "\u2753 Indeterminate",
        _ => "\u274c Failed"
    };

    private static string GetRuleMessageClass(string result) => result switch
    {
        "Failed" => "text-danger",
        "Not Evaluated" => "text-muted",
        _ => "text-warning"
    };

    private void ToggleSnapshot() => _showSnapshot = !_showSnapshot;

    private string GetFormattedJson()
    {
        return JsonSerializer.Serialize(Result, new JsonSerializerOptions { WriteIndented = true });
    }

    private void ExportJson()
    {
        // In a real app, this would trigger a JS download
        _showSnapshot = true;
    }
}
