  "derivedFields": {
    "IsSelfEmployed": {
      "source": "EmploymentStatus",
      "condition": "notEquals",
      "value": "Employed"
    },
    "IsResidentialMortgageLoan": {
      "source": "LoanType",
      "condition": "equals",
      "value": "Mortgage"
    },
    "IsInsuredMortgage": {
      "source": "LTV",
      "condition": "greaterThan",
      "value": "80"
    },
