    "Rules": [
      {
        "RuleName": "MinimumAgeRequirement",
        "Expression": "input.Age >= 18",
        "SuccessEvent": "Applicant meets minimum age requirement",
        "ErrorMessage": "Applicant must be at least 18 years of age",
        "Metadata": {
          "SourceDocumentId": "policy-doc-2024-001",
          "SourceUri": "https://contoso.com/policies/personal-loan-eligibility-2024.pdf",
          "PageNumber": 3,
          "CharRange": {
            "Start": 1024,
            "End": 1200
          }
        }
      },
      {
        "RuleName": "ResidencyRequirement",
        "Expression": "input.ResidencyStatus == \"Citizen\" || input.ResidencyStatus == \"PermanentResident\" || (input.ResidencyStatus == \"WorkPermit\" && input.WorkPermitRemainingMonths >= 12)",
        "SuccessEvent": "Applicant meets residency requirement",
        "ErrorMessage": "Applicant must be a Canadian citizen, permanent resident, or hold a valid work permit with at least 12 months remaining",
        "Metadata": {
          "SourceDocumentId": "policy-doc-2024-001",
          "SourceUri": "https://contoso.com/policies/personal-loan-eligibility-2024.pdf",
          "PageNumber": 3,
          "CharRange": {
            "Start": 1200,
            "End": 1400
          }
        }
      },
      {
        "RuleName": "MinimumIncomeRequirement",
        "Expression": "input.AnnualIncome >= 25000",
        "SuccessEvent": "Applicant meets minimum income requirement",
        "ErrorMessage": "Applicant gross annual income must be at least $25,000 CAD",
        "Metadata": {
          "SourceDocumentId": "policy-doc-2024-001",
          "SourceUri": "https://contoso.com/policies/personal-loan-eligibility-2024.pdf",
