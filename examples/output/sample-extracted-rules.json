        "Expression": "input.GDS <= 39",
        "SuccessEvent": "GDS ratio within acceptable limit",
        "ErrorMessage": "Applicant GDS ratio must not exceed 39%",
        "Metadata": {
          "SourceDocumentId": "policy-doc-2024-001",
          "SourceUri": "https://contoso.com/policies/personal-loan-eligibility-2024.pdf",
          "PageNumber": 3,
          "CharRange": {
            "Start": 1550,
            "End": 1650
          }
        }
      },
      {
        "RuleName": "MaxTotalDebtServiceRatio",
        "Expression": "input.TDS <= 44",
